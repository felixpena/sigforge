# SIG//FORGE Environment Configuration
# Copy to .env and fill in your values

# === REQUIRED ===
ANTHROPIC_API_KEY=sk-ant-...

# === POLYMARKET WALLET ===
POLYMARKET_PRIVATE_KEY=0x...
WALLET_ADDRESS=0xeB5df547a289f98C39C136EA52fB94F11c5e92Ad

# === INFRASTRUCTURE ===
REDIS_URL=redis://redis:6379

# === TRADING PARAMETERS ===
# CRITICAL: Keep PAPER_TRADING=true until system is validated
PAPER_TRADING=true
MAX_POSITION_SIZE_USD=100
SESSION_BANKROLL_USD=1000

# === AGENT CONFIGURATION ===
SCAN_INTERVAL_SECONDS=30
MAX_OPPORTUNITIES_PER_SCAN=12
MIN_LIQUIDITY_USD=5000
MIN_ANOMALY_SCORE=65
MIN_CONVICTION=65

# === CLAUDE MODEL ===
CLAUDE_MODEL=claude-sonnet-4-5
